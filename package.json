{
  "name": "overflayer",
  "version": "0.1.0",
  "description": "Persistent runtime layer on top of Mineflayer that hot-swaps snippet code without dropping the bot connection.",
  "main": "index.js",
  "bin": {
    "overflayer": "bin/overflayer.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node test/smoke.js",
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "web": "nuxt dev"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.1",
    "nuxt": "^4.4.6",
    "vec3": "^0.1.10",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "peerDependencies": {
    "mineflayer": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "mineflayer": {
      "optional": false
    }
  },
  "keywords": [
    "mineflayer",
    "minecraft",
    "bot",
    "hot-reload"
  ],
  "license": "MIT",
  "optionalDependencies": {
    "canvas": "^3.2.3",
    "mineflayer-pathfinder": "^2.4.5",
    "prismarine-viewer": "^1.33.0"
  }
}
